# ============================================================================
# SmartRoadVision — Environment Configuration
# Copy this file to `.env` and fill in real values.
# ============================================================================

# --- Application ---
APP_NAME=SmartRoadVision
APP_ENV=development                 # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-long-random-string
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                      # true => JSON logs, false => console renderer

# --- Models ---
MODELS_DIR=models
YOLO_WEIGHTS=models/yolov11-pothole.pt
YOLO_CONFIDENCE=0.35
YOLO_IOU=0.45
YOLO_IMGSZ=640
YOLO_DEVICE=auto                    # auto | cpu | cuda:0
YOLO_HALF=true
SAM2_CHECKPOINT=models/sam2_hiera_small.pt
SAM2_CONFIG=sam2_hiera_s.yaml
MIDAS_MODEL_TYPE=DPT_Hybrid         # DPT_Large | DPT_Hybrid | MiDaS_small
ENABLE_SEGMENTATION=true
ENABLE_DEPTH=true

# --- Severity weights (must sum to ~1.0) ---
SEVERITY_W_AREA=0.30
SEVERITY_W_DEPTH=0.35
SEVERITY_W_CONFIDENCE=0.15
SEVERITY_W_CLASS=0.20

# --- Database (PostgreSQL + PostGIS) ---
POSTGRES_USER=smartroad
POSTGRES_PASSWORD=smartroad_secret
POSTGRES_DB=smartroadvision
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://smartroad:smartroad_secret@postgres:5432/smartroadvision

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Reporting ---
REPORTS_DIR=reports
MAX_GALLERY_IMAGES=20

# --- Streaming ---
STREAM_MAX_FPS=30
STREAM_DENSITY_WINDOW=30
STREAM_DENSITY_ALERT_THRESHOLD=5

# --- Training (optional) ---
ROBOFLOW_API_KEY=
WANDB_API_KEY=
